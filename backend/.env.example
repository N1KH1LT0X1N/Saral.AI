# Backend Environment Variables
# Copy this file to .env and replace with your actual values
# SECURITY: Never commit .env files with real secrets!

# ============================================
# REQUIRED SECURITY CONFIGURATION
# ============================================

# JWT Secret for token signing (REQUIRED in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Google OAuth Client ID (REQUIRED for authentication)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============================================
# AI API KEYS
# ============================================

# Google Gemini API Key (REQUIRED)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Sarvam AI API Key (REQUIRED for TTS)
# Get from: https://sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Bhashini API Keys (for additional translation)
BHASHINI_USER_ID=your_bhashini_user_id
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_ULCA_API_KEY=your_bhashini_ulca_key

# Storage API Key (for persistent storage)
STORAGE_API_KEY=your_storage_api_key

# LaTeX Configuration (optional - auto-detected)
# PDFLATEX_PATH=C:\Program Files\MiKTeX\miktex\bin\x64\pdflatex.exe

# Server Configuration
# PORT=8000
# HOST=0.0.0.0
